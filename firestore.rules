rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if requesting user is super admin
    function isSuperAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Users can read/write their own document; super admins can read/write all user documents
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
    }

    // Public read for active modules; write for super admins only
    match /modules/{moduleId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Read/write analytics for super admins only
    match /analytics/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // Users can log events; read is restricted to super admins
    match /events/{eventId} {
      allow read: if isSuperAdmin();
      allow write: if request.auth != null;
    }
  }
}
